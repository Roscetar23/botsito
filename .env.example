# ===== API (NestJS) =====
PORT=3000
MONGODB_URI=mongodb://localhost:27017/asistente

# ----- Auth / JWT -----
JWT_ACCESS_SECRET=changeme-access
JWT_REFRESH_SECRET=changeme-refresh
