# ===== API (NestJS corre en :3001) =====
PORT=3001
MONGODB_URI=mongodb://localhost:27017/asistente

# ----- Auth / JWT -----
JWT_ACCESS_SECRET=changeme-access
JWT_REFRESH_SECRET=changeme-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- Realtime ----- (origen del cliente Next para CORS)
WS_CORS_ORIGIN=http://localhost:3000

# ===== NLU / LLM (opcional, Fase 6) =====
LLM_PROVIDER=anthropic
LLM_API_KEY=

# ===== Client (Next.js corre en :3000) =====
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001
